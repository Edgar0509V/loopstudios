---
import loopstudios from "../images/logo.svg";
import Hero from "../images/desktop/image-hero.jpg";
import Hamburguer from "../images/icon-hamburger.svg";
---

  <header class="relative w-full h-[80vh] md:h-162.5 text-white px-6 md:px-24 py-10">
  <img src={Hero.src} class="absolute inset-0 w-full h-full object-cover z-0 brightness-50"/>
  <div class="relative z-10 max-w-6xl mx-auto h-full flex flex-col">
    
    <div class="flex justify-between items-center">
      <img src={loopstudios.src} alt="loopstudios" class="w-32 md:w-40" />
      
      <nav class="hidden md:flex space-x-8 font-bold text-sm">
        <a href="#" class="hover:border-b-2 border-white pb-1">About</a>
        <a href="#" class="hover:border-b-2 border-white pb-1">Careers</a>
        <a href="#" class="hover:border-b-2 border-white pb-1">Events</a>
        <a href="#" class="hover:border-b-2 border-white pb-1">Products</a>
        <a href="#" class="hover:border-b-2 border-white pb-1">Support</a>
      </nav>
      <div class="md:hidden">
        <img src={Hamburguer.src} alt="menu" class="w-6" />
      </div>
    </div>

    <div class="mt-20 md:mt-32 border-2 border-white p-6 md:p-10 max-w-xl">
      <h1 class="text-4xl md:text-5xl uppercase font-light leading-tight tracking-widest">
        Immersive <br> experiences <br> that deliver
      </h1>
    </div>

  </div>
</header>



