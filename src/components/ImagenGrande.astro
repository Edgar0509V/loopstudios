---
import Interactivo from "../images/desktop/image-interactive.jpg";
---
<section class="flex min-h-screen items-center justify-center">
  <div class="container mx-auto max-w-6xl shadow-xl overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-12 items-end"> 
      <div class="md:col-start-1 md:col-end-9 md:row-start-1">
        <img src={Interactivo.src} class="w-full h-auto"/>
      </div>
      <div class="bg-white p-8 md:p-16 lg:p-20 md:col-start-8 md:col-end-13 md:row-start-1 md:mt-40">
        <h2 class="text-4xl uppercase mb-6 leading-tight text-gray-800">
          The leader in interactive VR
        </h2>
        <p class="text-gray-600 leading-relaxed">
          Founded in 2011, Loopstudios has been producing world-class 
          virtual reality projects for some of the best companies around 
          the globe. Our award-winning creations have transformed 
          businesses through digital experiences that bind to their brand.
        </p>
      </div>
    </div>
  </div>
</section>